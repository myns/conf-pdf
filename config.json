{
  "auth": {
    "base_url": "https://confluence.your-company.com",
    "username": "YOUR_USERNAME",
    "password": "YOUR_PASSWORD"
  },

  "target": {
    "space_key": "YOUR_SPACE_KEY",
    "page_id": null,
    "page_title": null
  },

  "scroll_pdf": {
    "templateId": null,

    "scope": "descendants",

    "locale": "tr-TR",

    "timeZone": "Europe/Istanbul",

    "versionId": null,

    "variantId": null,

    "languageKey": null
  },

  "output": {
    "output_dir": "./output",
    "filename_pattern": "{space_key}_{datetime}",
    "datetime_format": "%Y-%m-%d_%H-%M-%S"
  },

  "safety": {
    "request_timeout_sec": 60,
    "poll_interval_sec": 10,
    "max_poll_attempts": 30,
    "max_retries": 3,
    "retry_backoff_factor": 2
  },

  "ssl": {
    "verify_ssl": true,
    "ca_bundle_path": null
  },

  "logging": {
    "level": "INFO",
    "log_to_file": false,
    "log_file": "./exporter.log"
  }
}
